   "id": "363c9cfb",
   "metadata": {},
   "outputs": [
    {
     "data": {
      "text/plain": [
       "tensor([[[-1., -0.,  1.],\n",
       "         [-1.,  0.,  1.]],\n",
       "\n",
       "        [[ 0., -1.,  2.],\n",
       "         [-2.,  1.,  0.]],\n",
       "\n",
       "        [[ 1., -2.,  3.],\n",
       "         [-3.,  2., -1.]],\n",
       "\n",
       "        [[ 2., -3.,  4.],\n",
       "         [-4.,  3., -2.]],\n",
       "\n",
       "        [[ 3., -4.,  5.],\n",
       "         [-5.,  4., -3.]]])"
      ]
     },
     "execution_count": 7,
     "metadata": {},
     "output_type": "execute_result"
    }
   ],
   "source": [
    "top = torch.cat([B-1,-B,B+1],dim=-1)\n",
    "bottom = torch.cat([-B-1,B,-B+1],dim=-1)\n",
    "\n",
    "t = torch.cat([top,bottom],dim=-2)\n",
    "t"
   ]
